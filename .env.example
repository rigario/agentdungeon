# =============================================================================
# AgentDungeon / D20 Agent RPG — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values before deploying.
#
#   cp .env.example .env
#
# This file is committed to git. NEVER commit a real .env file.
# Leave optional secrets blank unless you enable the related integration.
# =============================================================================

# === Rules Server ===
D20_DB_PATH=/app/data/d20.db
D20_PORT=8600
D20_HOST=0.0.0.0
D20_BASE_URL=http://localhost:8600
D20_RNG_SEED=agentdungeon
REDIS_URL=redis://d20-redis:6379/0

# === OAuth (optional) ===
# Leave blank for local/dev mock login where supported.
D20_GOOGLE_CLIENT_ID=
D20_GOOGLE_CLIENT_SECRET=
D20_TWITTER_CLIENT_ID=
D20_TWITTER_CLIENT_SECRET=

# === Encryption ===
# Generate a strong value before using OAuth or encrypted credentials in production.
D20_ENCRYPTION_KEY=

# === DM Runtime ===
DM_PORT=8610
DM_HOST=0.0.0.0
DM_RULES_SERVER_URL=http://d20-rules-server:8600
DM_REDIS_URL=redis://d20-redis:6379/0
DM_NARRATOR_ENABLED=true
DM_NARRATOR_MODEL=kimi-k2.5
DM_NARRATOR_TIMEOUT=110
DM_NARRATOR_MAX_TOKENS=1200
DM_HERMES_MODE=hermes
DM_HERMES_PROFILE=d20-dm
HERMES_HOME=/root/.hermes

# === LLM Provider ===
# Configure the provider used by the DM runtime. For Kimi/Moonshot-compatible
# endpoints, set KIMI_API_KEY and optionally KIMI_BASE_URL.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional proxy/provider credentials if you route narration through another gateway.
FIRE_PASS_API_KEY=
DM_FIRE_PASS_API_KEY=
DM_FIRE_PASS_BASE_URL=https://api.firepass.ai/v1

# === Internal Service Auth ===
# Shared secret used between the rules server and DM runtime if enabled.
DM_RUNTIME_SHARED_SECRET=

# === Public Deployment ===
PUBLIC_BASE_URL=https://your-domain.example
PUBLIC_DOMAIN=your-domain.example
TRAEFIK_NETWORK=proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
